{
  "name": "curalink-backend",
  "version": "1.0.0",
  "description": "AI-powered clinical research assistant backend using Node.js, Express, MongoDB, and Ollama",
  "main": "server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "clean": "rm -rf node_modules package-lock.json",
    "reinstall": "npm run clean && npm install"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "node-cache": "^5.1.2",
    "xml2js": "^0.6.2"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
